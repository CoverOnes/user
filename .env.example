# CoverOnes user service — environment variable reference.
# Copy to .env for local development. NEVER commit a real .env.
# All variables are prefixed with USER_ (viper SetEnvPrefix).

# ── Server ────────────────────────────────────────────────────────────────────
USER_PORT=8080
USER_ENV=development
USER_LOG_LEVEL=INFO

# ── Postgres ──────────────────────────────────────────────────────────────────
# DSN format: postgres://user:password@host:5432/dbname?sslmode=disable
USER_POSTGRES_DSN=postgres://REPLACE_ME:REPLACE_ME@localhost:5432/coverones_user?sslmode=disable

# Optional: Postgres schema for schema-based isolation on a shared Aiven database.
# Leave empty (default) to use the public schema with a dedicated database.
# Set to "user" when all CoverOnes services share ONE Aiven database and must be
# isolated by Postgres schema (search_path). Only [a-zA-Z0-9_] characters allowed.
# USER_DB_SCHEMA=user

# Optional: pgxpool connection-count tuning (defaults: max=10, min=2).
# Lower these when running 8+ services against a small Aiven plan to avoid
# exhausting the server's max_connections (e.g. USER_DB_MAX_CONNS=3 USER_DB_MIN_CONNS=1).
# USER_DB_MAX_CONNS=10
# USER_DB_MIN_CONNS=2

# ── Redis (optional — rate limiting only) ─────────────────────────────────────
# Leave empty to run without rate limiting in local dev.
USER_REDIS_URL=redis://localhost:6379/0

# ── JWT Ed25519 private key ───────────────────────────────────────────────────
# Base64-encoded 32-byte seed (NOT a real key — generate with: openssl genpkey -algorithm ed25519 | openssl pkey -outform DER | tail -c 32 | base64)
# Leave empty to use an ephemeral key on each restart (dev only).
# NOTE: the variable name MUST match config.go (USER_JWT_PRIVATE_KEY) and dev-stack;
# a mismatched name silently falls back to an ephemeral key in production.
USER_JWT_PRIVATE_KEY=REPLACE_WITH_REAL_BASE64_32BYTE_SEED

# Alternative: PKCS8 PEM (mutually exclusive with the above)
# USER_JWT_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----...

# ── Event HMAC secret (kyc.tier_changed message authentication) ────────────────
# Shared secret (min 32 chars) used to authenticate inbound Redis events. Read from
# the UN-prefixed EVENT_HMAC_SECRET (NOT USER_-prefixed) so this consumer and the kyc
# publisher use the identical variable name. Required (non-empty) outside development;
# an unsigned or wrongly-signed event is dropped (a forged Redis event cannot elevate
# a user's KYC tier). Generate with: openssl rand -base64 48
# MUST be the SAME value as the kyc service's EVENT_HMAC_SECRET — a mismatch silently drops all KYC tier promotions.
EVENT_HMAC_SECRET=REPLACE_ME_min32chars

# ── Token TTLs ────────────────────────────────────────────────────────────────
USER_ACCESS_TOKEN_TTL_SEC=600
USER_REFRESH_TOKEN_TTL_HOURS=24

# ── TOTP 2FA (Increment 3) ────────────────────────────────────────────────────
# USER_TOTP_ISSUER is the issuer label embedded in the otpauth:// provisioning URI
# and shown by authenticator apps (Google Authenticator etc.). Defaults to
# "CoverOnes". MUST be non-empty and MUST NOT contain a colon (the otpauth label is
# "<issuer>:<account>", so a colon would corrupt it).
USER_TOTP_ISSUER=CoverOnes
# USER_MFA_ENFORCED is RESERVED for the future login-enforcement step. When a later
# increment ships, true will require a TOTP challenge in login for mfa-enabled users.
# It is NOT acted on in the current increment — login is unchanged — so leave it
# false. Defaults to false.
USER_MFA_ENFORCED=false

# ── PII encryption (legal_name / national_id / TOTP secret at rest) ───────────
# AES-256 key, base64-encoded — MUST decode to exactly 32 bytes outside development.
# There is NO plaintext fallback: a usable key is required in EVERY environment
# (a documented dev-default keeps the encrypt path exercised locally).
# Generate with: openssl rand -base64 32
USER_PII_ENCRYPTION_KEY=REPLACE_ME_base64_32_bytes_openssl_rand_base64_32

# ── SMTP (email verification mailer) ──────────────────────────────────────────
# USER_SMTP_HOST is REQUIRED outside development (verification mail must be sendable).
# In local dev, leave USER_SMTP_HOST empty to skip sending (register still returns 201),
# or point it at a local MailHog/Mailpit (host=localhost port=1025, no auth).
USER_SMTP_HOST=REPLACE_ME_smtp_host
USER_SMTP_PORT=587
USER_SMTP_USERNAME=REPLACE_ME_smtp_username
USER_SMTP_PASSWORD=REPLACE_ME_smtp_password
USER_SMTP_FROM=no-reply@coverones.example

# ── App / frontend ────────────────────────────────────────────────────────────
# USER_APP_BASE_URL is the public frontend base URL used to build the clickable
# verification link in the email: <USER_APP_BASE_URL>/verify-email?token=<token>.
# Defaults to the dev frontend origin below when unset (no fail-fast). Set it to
# the real frontend origin in staging/production (e.g. https://app.coverones.com).
USER_APP_BASE_URL=http://localhost:5500
